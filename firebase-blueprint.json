{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Topic Sandbox application.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
          "type": "string",
          "description": "User role, e.g., 'user' or 'admin'."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created."
        }
      },
      "required": ["email", "createdAt"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global configuration for the platform.",
      "type": "object",
      "properties": {
        "targetDate": { "type": "string", "format": "date" }
      },
      "required": ["targetDate"]
    },
    "DailyGoal": {
      "title": "Daily Goal",
      "description": "User's daily extraction target.",
      "type": "object",
      "properties": {
        "target": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["target", "date"]
    },
    "ModelCard": {
      "title": "Model Card",
      "description": "A recorded empirical model from a paper.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created this card."
        },
        "uploaderName": {
          "type": "string",
          "description": "The name of the user who uploaded this card."
        },
        "title": {
          "type": "string",
          "description": "Paper title."
        },
        "journal": {
          "type": "string",
          "description": "Journal name."
        },
        "conceptualMap": {
          "type": "string",
          "description": "Text description of the conceptual map (X->M->Y)."
        },
        "iv": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Independent Variables (X)."
        },
        "mediator": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Mediating Variables (M)."
        },
        "moderator": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Moderating Variables (W)."
        },
        "dv": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Dependent Variables (Y)."
        },
        "wowFactor": {
          "type": "string",
          "description": "The most clever/counter-intuitive part of the paper."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the card was created."
        }
      },
      "required": ["userId", "title", "journal", "iv", "dv", "createdAt"]
    },
    "SimulatedTopic": {
      "title": "Simulated Topic",
      "description": "A new topic generated by combining variables in the lab.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who created this topic."
        },
        "iv": {
          "type": "string",
          "description": "Selected Independent Variable."
        },
        "mediator": {
          "type": "string",
          "description": "Selected Mediating Variable."
        },
        "moderator": {
          "type": "string",
          "description": "Selected Moderating Variable."
        },
        "dv": {
          "type": "string",
          "description": "Selected Dependent Variable."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes for this simulated topic."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the topic was created."
        }
      },
      "required": ["userId", "iv", "dv", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/users/{userId}/dailyGoals/{date}": {
      "schema": { "$ref": "#/entities/DailyGoal" },
      "description": "Stores user's daily goals."
    },
    "/systemConfig/{configId}": {
      "schema": { "$ref": "#/entities/SystemConfig" },
      "description": "Stores global system configuration."
    },
    "/modelCards/{cardId}": {
      "schema": { "$ref": "#/entities/ModelCard" },
      "description": "Stores model cards created by users."
    },
    "/simulatedTopics/{topicId}": {
      "schema": { "$ref": "#/entities/SimulatedTopic" },
      "description": "Stores simulated topics generated by users."
    }
  }
}
